[sub_resource type="GDScript" id="GDScript_niitk"]
resource_name = "dadsad"
script/source = "extends \"res://scripts/game/level/door.gd\"

var tweening = false

func use_end():
	pass

func use_start():
	pass

func _entered(body):
	if tweening==true:
		return
	if body is CharacterBody2D:
		tweening=true
		var tw = create_tween()
		tw.tween_property(self,\"position\",Vector2(1000, position.y),5)

func _ready() -> void:
	get_node(\"Area2D\").body_entered.connect(_entered)
"

