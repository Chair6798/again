[sub_resource type="GDScript" id="GDScript_v1pya"]
resource_name = "cr"
script/source = "extends StaticBody2D

var cracks = 3

func crack():
	if cracks==0:
		cracks=-1
		get_node(\"planks\").play()
		var tw2 = create_tween()
		tw2.tween_property(self,\"rotation_degrees\",-40,0.1)
		
		return
	elif cracks<0:
		return
	else:
		cracks-=1
		get_node(\"cracksound\").play()
		var tw = create_tween()
		tw.tween_property(self,\"rotation_degrees\",-10,0.1)
		await tw.finished
		tw = create_tween()
		tw.tween_property(self,\"rotation_degrees\",0,0.1)
"

[sub_resource type="RectangleShape2D" id="RectangleShape2D_v1pya"]
size = Vector2(300, 50)

[sub_resource type="GDScript" id="GDScript_qsj6i"]
resource_name = "crack1"
script/source = "extends Area2D

func _body_entered(body):
	if body.name==\"Player\":
		get_parent().crack()

func _body_exited(_body):
	pass

func _ready() -> void:
	body_entered.connect(_body_entered)
"

