[sub_resource type="GDScript" id="GDScript_557n5"]
resource_name = "1111"
script/source = "extends \"res://scripts/game/level/button.gd\"


func _entered(body):
	if not enabled:
		return
	
	if get_parent().get_parent().is_ready==false:
		return
	if (body is CharacterBody2D)  or (body is RigidBody2D):
		collided+=1
		_down()
func _leaved(body):
	if not enabled:
		return
	
	if get_parent().get_parent().is_ready==false:
		return
	if (body is CharacterBody2D)  or (body is RigidBody2D):
		collided-=1
		if collided==0:
			_up()
func _down():
	get_parent().get_parent().get_parent().get_node(\"Audio\").get_node(\"Button\").play()
	$Sprite2D2.position=Vector2(0,0)
	ConnectedObject.use_start()

func _up():
	get_parent().get_parent().get_parent().get_node(\"Audio\").get_node(\"Button\").play()
	$Sprite2D2.position=Vector2(0,-9)
	ConnectedObject.use_end()
"

