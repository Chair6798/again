resource_name = "texteditt"
script/source = "extends LineEdit

func _changed():
	print(\"Changed!\")
	if text==\"кнопка\":
		get_parent().get_node(\"Button\").visible=true
		get_parent().get_node(\"Button\").get_node(\"CollisionShape2D\").disabled=false

func _ready() -> void:
	get_parent().get_node(\"conf\").pressed.connect(_changed)
"

