func _ready() -> void:
	super._ready()
	
"

[sub_resource type="GDScript" id="GDScript_xn6kt"]
resource_name = "levellist"
script/source = "extends ItemList

var lock_texture = preload(\"res://texture/ui/locked.png\")

func _picked(a):
	Root.load_level_number(a+1)

func _ready() -> void:
	item_selected.connect(_picked)

func update():
	while item_count>0:
		remove_item(0)
	
	var c = Root.level_count
	for i in range(1,c+1):
		var id = add_item(str(i))
		if Root.lastavaiable<i:
			set_item_icon(id,lock_texture)
"

[sub_resource type="GDScript" id="GDScript_247la"]
resource_name = "exitlist"
script/source = "extends Button

func _pressed() -> void:
	get_parent().visible=false
	get_parent().get_parent().get_node(\"level_list\").visible=false
	get_parent().get_parent().get_node(\"mainbuttons\").visible=true
"

[sub_resource type="GDScript" id="GDScript_hj162"]
resource_name = "playbtn"
script/source = "extends Button

func _pressed() -> void:
	Root.load_level_number(Root.currentLevel)
"

[sub_resource type="GDScript" id="GDScript_nl8w3"]
resource_name = "levelsbtn"
script/source = "extends Button

func _pressed() -> void:
	get_parent().get_parent().get_parent().get_node(\"level_list\").visible=true
	get_parent().get_parent().get_parent().get_node(\"exit_list_button\").visible=true
	get_parent().get_parent().get_parent().get_node(\"level_list\").update()
	get_parent().get_parent().visible=false
"

