[sub_resource type="GDScript" id="GDScript_d4hu8"]
resource_name = "confirmreset"
script/source = "extends ConfirmationDialog

func _yes():
	Root.resetdata()
	visible=false
func _no():
	visible=false
#func _seet():
	#position=Vector2(-200,-150)
func _ready() -> void:
	#_seet()
	#visibility_changed.connect(_seet)
	canceled.connect(_no)
	confirmed.connect(_yes)
"

[sub_resource type="GDScript" id="GDScript_p1nwe"]
resource_name = "ruflag"
script/source = "extends TextureButton


# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	pressed.connect(_onpress)

func _onpress():
	get_parent().visible=false
	get_parent().get_parent().get_node(\"mainbuttons\").visible=true
	TranslationServer.set_locale(name)

# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(delta: float) -> void:
	pass
"

