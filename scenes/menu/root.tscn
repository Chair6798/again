[sub_resource type="GDScript" id="GDScript_1i28j"]
resource_name = "intro_autoscale"
script/source = "extends Control

func _scale():
	position=-get_viewport_rect().size/2*(1/get_viewport().get_camera_2d().zoom.x)
	scale=Vector2(1/get_viewport().get_camera_2d().zoom.x,1/get_viewport().get_camera_2d().zoom.y)
func run_intro():
	await get_tree().process_frame
	get_node(\"AnimationPlayer\").play(\"intro\")
	await get_tree().create_timer(2.8).timeout
	visible=false
func _ready() -> void:
	_scale()
	get_viewport().size_changed.connect(_scale)
"

