[sub_resource type="GDScript" id="GDScript_prryt"]
resource_name = "level_loader_label_counter"
script/source = "extends Label
var maximal:int=10
var value:int=0
@export var progreesbar:ProgressBar
func add():
	value+=1
	if value>maximal:
		push_warning(\"Значение закруженных слишком большое! Спуск до максимума!\")
		value=maximal
	progreesbar.max_value=maximal
	progreesbar.value=value
	render_text()
func set_max(newmax:int):
	maximal=newmax
	if value>maximal:
		push_warning(\"Значение закруженных слишком большое! Спуск до максимума!\")
	progreesbar.max_value=maximal
	progreesbar.value=value
	render_text()

func render_text():
	text=str(value)+\"/\"+str(maximal)

func set_value(count_loads:int):
	value=count_loads
	if value>maximal:
		push_warning(\"Значение закруженных слишком большое! Спуск до максимума!\")
		value=maximal
	progreesbar.max_value=maximal
	progreesbar.value=value
	render_text()
func _ready() -> void:
	render_text()
"

[sub_resource type="GDScript" id="GDScript_yjlgg"]
resource_name = "levels_err_label_script"
script/source = "extends Label
var errors:int=0
func add_error():
	errors+=1
	render_text()
func set_errors(count:int):
	errors=count
	render_text()
func render_text():
	text=\"Ошибок: \"+str(errors)

func _ready() -> void:
	render_text()
"

