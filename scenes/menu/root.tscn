[sub_resource type="Shader" id="Shader_rhth7"]
code = "shader_type canvas_item;

// Эта переменная появится в инспекторе, чтобы ты мог менять масштаб
uniform vec2 tiling_scale = vec2(2.0, 2.0); 
uniform float time_mod = 1;
void fragment() {
    // Мы умножаем координаты текстуры на масштаб, чтобы она повторялась чаще
    COLOR = texture(TEXTURE,fract(UV * tiling_scale+vec2(TIME*time_mod,TIME*time_mod)));
}"

